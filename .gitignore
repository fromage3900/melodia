# ===== Unreal Engine project .gitignore =====
# Generated/transient — never commit
Binaries/
DerivedDataCache/
Intermediate/
LocalDerivedDataCache/
Saved/
Build/

# Plugin build artifacts (keep plugin Source/Content, ignore compiled)
Plugins/**/Binaries/
Plugins/**/Intermediate/

# IDE / OS
.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.opensdf
*.opendb
*.sdf
*.suo
*.sln
*.xcodeproj
*.xcworkspace
Thumbs.db
Desktop.ini
.DS_Store

# Diversion metadata (if using Diversion instead of GitHub)
.diversion/
.dvignore

# Keep these (do NOT ignore): Config/, Content/, Source/, *.uproject, .gitattributes, Docs/

# Large local import staging (FBX/VRM binaries)
Content/Import/**/*.fbx
Content/Import/**/*.vrm
build_log.txt

# UI asset staging — keep flat PNGs/TTFs only, not nested git clones
Content/Melodia/UI/Sprites/**/.git/
Content/Melodia/UI/Sprites/_tmp_*/
Content/Melodia/UI/Sprites/_test/
Content/Melodia/UI/Sprites/SparkleUI/
Content/Melodia/UI/Fonts/_extracted/

# Python cache
Scripts/**/__pycache__/
