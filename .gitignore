# ===== Unreal Engine project .gitignore =====
# Generated/transient — never commit
Binaries/
DerivedDataCache/
Intermediate/
LocalDerivedDataCache/
Saved/
Build/

# Plugin build artifacts (keep plugin Source/Content, ignore compiled)
Plugins/**/Binaries/
Plugins/**/Intermediate/

# IDE / OS
.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.opensdf
*.opendb
*.sdf
*.suo
*.sln
*.xcodeproj
*.xcworkspace
Thumbs.db
Desktop.ini
.DS_Store

# Diversion metadata (if using Diversion instead of GitHub)
.diversion/
.dvignore

# Keep these (do NOT ignore): Config/, Content/, Source/, *.uproject, .gitattributes, Docs/
