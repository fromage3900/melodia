	// {
	// 	return MeshBlend_MinSize.z;
	// }
	//
	// if (Value <= StencilEndExtraLarge)
	// {
	// 	return MeshBlend_MinSize.w;
	// }
	//
	// return 0;
}

float3 GetBlendSizeColor(float Value)
{
	const float StencilStartSmall = 2;
	const float StencilStartMedium = 65;
	const float StencilStartLarge = 128;
	const float StencilStartExtraLarge = 191;
	const float StencilRange = 62;
	float3 Result = float3(1, 1, 1);
	Value *= 255.0;

	if (Value >= StencilStartSmall && Value <= StencilStartSmall + StencilRange)
	{
		return Result * float3(0, 1, 0) * lerp(1, 0.5, ((Value - StencilStartSmall) / StencilRange));
	}
	else if (Value >= StencilStartMedium && Value <= StencilStartMedium + StencilRange)
	{
		return Result * float3(0, 1, 1) * lerp(1, 0.5, ((Value - StencilStartMedium) / StencilRange));
	}
	else if (Value >= StencilStartLarge && Value <= StencilStartLarge + StencilRange)
	{
		return Result * float3(0, 0, 1) * lerp(1, 0.5, ((Value - StencilStartLarge) / StencilRange));
	}
	else if (Value >= StencilStartExtraLarge && Value <= StencilStartExtraLarge + StencilRange)
	{
		return Result * float3(1, 0, 0) * lerp(1, 0.5, ((Value - StencilStartExtraLarge) / StencilRange));
	}

	return Result;
}

float GetMaxFade(float FadeSize, float MinSizeFactor, float DepthScaleInv, float ViewPortFactor)
{
	float FadeSizeMultiplied = FadeSize * 1000.0;
	float MaxFade = FadeSizeMultiplied * MinSizeFactor * DepthScaleInv;
	return min3(MaxFade, PostProcessOutput_Extent.y * 0.2, FadeSizeMultiplied * max(DepthScaleInv, 0.001));
}

float2 SvPositionToUV(float2 Pos)
{
	float2 ViewportUV = ((Pos - PostProcessOutput_ViewportMin.xy) * PostProcessOutput_ViewportSizeInverse.xy);
	return ViewportUV * PostProcessOutput_UVViewportSize + PostProcessOutput_UVViewportMin;
}

float4 UVToSvPosition(float2 UV, float4 SvPosition)
{
	float2 ViewportUV = (UV - PostProcessOutput_UVViewportMin) * PostProcessOutput_UVViewportSizeInverse;
	float2 Pos = ViewportUV * PostProcessOutput_ViewportSize + PostProcessOutput_ViewportMin.xy;
	return float4(Pos, SvPosition.zw);
}

float3 GetWorldPosition(float4 SvPosition, float Depth)
{
	SvPosition.z = ConvertToDeviceZ(Depth);
	SvPosition.z = max(SvPosition.z, 1e-18);
	float3 TranslatedWorldPosition = SvPositionToTranslatedWorld(SvPosition);
	float3 AbsoluteWorldPosition = TranslatedWorldPosition.xyz - LWCHackToFloat(ResolvedView.PreViewTranslation).xyz;
	return AbsoluteWorldPosition;
}


float CalculateAngle(float3 A, float3 B, float3 C)
{
	float3 BA = normalize(A - B);
	float3 BC = normalize(C - B);

	// Compute the cross product and dot product
	float3 CrossProd = cross(BA, BC);
	float DotProd = dot(BA, BC);

	// Compute the angle in radians using atan2
	float ThetaRadians = atan2(length(CrossProd), DotProd);

	// Convert the angle from radians to degrees
	float ThetaDegrees = degrees(ThetaRadians);

	// Clamp the angle to the range [0..1] from [60..0] degrees incline
	return 1.0 - pow(1.0 - saturate((ThetaDegrees - 120) / 60.0), 5);
}

float FastCalculateAngle(float3 A, float3 B, float3 C)
{
	const float3 BA = normalize(A - B);
	const float3 BC = normalize(C - B);

	//Cos range -1 to 1
	const float DotProd = dot(BA, BC);

	//The comment for the normal function seems a little deceiving because that range is actually 120->180
	// For angle range from 120° to 180°, we map: 
	// cos(120°) = -0.5, cos(180°) = -1 → target range: [0..1]
	return 1.0 - pow(1.0 - saturate((-DotProd - 0.5) / 0.5), 5.0);
}
